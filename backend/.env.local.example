# Copy to .env.local and fill in values for local development.
# This file is committed; .env.local is gitignored.

# --- S3 / MinIO ---
S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Embedding provider ---
# Option A: OpenAI (takes priority if key is set)
OPENAI_API_KEY=

# Option B: Ollama local fallback (used when OPENAI_API_KEY is empty)
# Requires pulling models on the host:
#   ollama pull nomic-embed-text   (embeddings)
#   ollama pull llama3.2           (chat)
# nomic-embed-text outputs 768-dim vectors — set EMBEDDING_DIMENSIONS to match,
# then re-run `alembic upgrade head` to resize the DB column.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2
EMBEDDING_DIMENSIONS=768
